// =====================================================================
//  ROADSEN — schema.prisma  (PostgreSQL, multi-tenant SaaS)
//
//  Socle minimal (issue #38). Sous-ensemble REEL de la conception
//  (02-Conception/schema.prisma) : juste de quoi prouver l'isolation
//  multi-tenant de bout en bout (Organization → Membership → Project).
//
//  Conventions (alignees sur la conception) :
//   - Toute table METIER porte orgId NON-NULL (pivot d'isolation, FK -> organizations).
//   - PK uuid ; mapping snake_case via @@map / @map.
//   - Prisma seul NE garantit PAS l'isolation : la 1ere migration SQL
//     active RLS (ENABLE + FORCE) + policies. Voir
//     prisma/migrations/0001_init_rls/migration.sql.
//   - L'app pose `SET LOCAL app.current_org = '<uuid>'` par transaction.
//     RLS = filet ; le guard applicatif = defense en profondeur.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ----------------------- Identite / tenant / RBAC -----------------------

enum OrgStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

// Role AU SEIN d'un tenant (porte par Membership).
enum Role {
  OWNER
  ADMIN
  ENGINEER // ingenieur
  TECHNICIAN // technicien-sondeur
  VIEWER
}

// Role PLATEFORME (transverse, hors tenant) — back-office STARFIRE.
enum PlatformRole {
  SUPERADMIN
  SUPPORT
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  status    OrgStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  memberships  Membership[]
  projects     Project[]
  subscription Subscription? // 1:1 logique en P1 (org_id UNIQUE cote subscriptions)

  @@map("organizations")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  passwordHash String?       @map("password_hash")
  fullName     String        @map("full_name")
  platformRole PlatformRole? @map("platform_role")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  memberships Membership[]

  @@map("users")
}

// User x Organization + role tenant. Un utilisateur peut appartenir a
// plusieurs organisations ; le couple (orgId, userId) est unique.
model Membership {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role
  // Suspension d'accès sans suppression (migration 0010). Un membre inactif ne
  // porte plus de rôle : auth_user_has_membership filtre is_active=true.
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
  @@map("memberships")
}

// ----------------------- Table metier porteuse de donnees -----------------------

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Domaine metier d'un projet — porte le cloisonnement fonctionnel des logiciels :
// chaque logiciel (terzaghi/casagrande/... = FD, roadsens = CH, fastlab/pressiopro
// = LB) ne liste que les projets de SON domaine. CH = chaussees, FD = fondations,
// LB = laboratoire/sols.
enum ProjectDomain {
  CH
  FD
  LB
}

// Table metier minimale, presente uniquement pour PROUVER l'isolation
// (un tenant ne voit jamais les projets d'un autre, RLS + guard).
model Project {
  id          String         @id @default(uuid()) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  name        String
  // P0-5 : la modale proposait ce champ depuis toujours, mais aucune colonne
  // n'existait et zod le retirait -> la saisie disparaissait en silence.
  // NULLABLE : les projets anterieurs n'en ont pas, et imposer une chaine vide
  // inventerait une donnee.
  description String?
  status      ProjectStatus  @default(DRAFT)
  // NULLABLE a dessein : les projets crees AVANT l'ajout de la colonne (0022) ont
  // un domaine INCONNU -> null, pas de defaut silencieusement faux. Un projet
  // domain=null reste selectionnable dans tous les logiciels (cote front).
  domain      ProjectDomain? @map("domain")
  createdById String         @map("created_by_id") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  // Date du DERNIER archivage (0026). NULLABLE, et c'est le contrat : null = ce
  // projet n'est pas archive (restore() la remet a null). `updated_at` ne pouvait
  // pas servir — il bouge a chaque renommage, donc il ne date pas le geste. Les
  // projets archives AVANT 0026 restent a null : leur date n'a jamais ete
  // enregistree, l'inventer serait une donnee fausse.
  archivedAt  DateTime?      @map("archived_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  calcs CalcResult[]

  @@unique([orgId, id]) // cible de FK COMPOSITE (org_id, .) des tables enfant (0006)
  @@index([orgId])
  @@index([orgId, status])
  // Couvre la vue « Archives » (0026) : filtre org (RLS) + tri archived_at DESC.
  @@index([orgId, archivedAt(sort: Desc)])
  @@map("projects")
}

// ----------------------- Pipeline PV : calcul -> PV scelle (#63, incr. A) -----------------------
//
//  calc_results : calcul org-scope MUTABLE/jetable (recalcul serveur). official_pvs :
//  PV OFFICIEL IMMUABLE et AUTOPORTANT (copie figee de ce qui a ete scelle).
//  RLS FORCE + policies + triggers d'immuabilite + numerotation : portes par la
//  migration SQL 0006 (Prisma seul ne les exprime pas). Voir
//  prisma/migrations/0006_pv_seal_core/migration.sql.

// Calcul persiste (jetable). input/output = JSON projete/whiteliste (jamais de champ
// libre : la projection cote @roadsen/shared strippe les intermediaires avant stockage).
model CalcResult {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  engineId         String   @map("engine_id")
  engineVersion    String   @map("engine_version")
  engineSourceHash String?  @map("engine_source_hash")
  input            Json     @db.JsonB
  output           Json     @db.JsonB
  createdAt        DateTime @default(now()) @map("created_at")

  // FK COMPOSITE (orgId, projectId) -> projects(orgId, id) : un calcul ne reference
  // qu'un projet de SON tenant (anti cross-tenant, cf. NOTE §4 de 0004).
  project  Project       @relation(fields: [orgId, projectId], references: [orgId, id], onDelete: Cascade)
  // Capture du document client (option-3) — relation 1-1 optionnelle (0023).
  snapshot CalcSnapshot?

  @@unique([orgId, id]) // org-coherence de l'id local
  @@index([orgId])
  @@index([orgId, projectId])
  // P0-6 : couvre « dernier calcul du projet » (agregat de P0-3) sans tri apres coup.
  @@index([orgId, projectId, createdAt(sort: Desc)])
  @@map("calc_results")
}

// Capture du DOCUMENT que l'outil client produit A L'IMPRESSION (scellement option-3,
// #63/0023) : HTML/SVG auto-contenu, deterministe. Filtre par la garde §8 a la capture
// (best-effort ; l'inertie EFFECTIVE au ré-affichage vient de la CSP HTTP du service).
// Relation 1-1 avec CalcResult (le calcul est immuable -> la capture est deterministe
// -> re-capturer ECRASE, UPSERT par calcResultId). Table de DONNEES mutable, org-scope
// (RLS FORCE + policy en 0023). display_html = affichage ; print_html = impression,
// dont le sha256 entre dans le sceau du PV (integrite re-verifiable, cf. pv.service).
model CalcSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  calcResultId String   @unique @map("calc_result_id") @db.Uuid
  displayHtml  String   @map("display_html")
  printHtml    String   @map("print_html")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // FK COMPOSITE (orgId, calcResultId) -> calc_results(orgId, id) : une capture ne
  // reference qu'un calcul de SON tenant (anti cross-tenant, patron 0006).
  calcResult CalcResult @relation(fields: [orgId, calcResultId], references: [orgId, id], onDelete: Cascade)

  @@unique([orgId, calcResultId]) // cote definissant du 1-1 sur la FK composite
  @@index([orgId])
  @@map("calc_snapshots")
}

// PV OFFICIEL : AUTOPORTANT (copie figee de TOUT le contenu scelle, DOCUMENT CLIENT
// INCLUS) et IMMUABLE (triggers BEFORE UPDATE/DELETE en 0006 ; aucun privilege
// UPDATE/DELETE pour le runtime). Pas de FK vivante vers projects/calc_results : le
// PV survit a leur suppression. calcResultId / projectId sont conserves comme
// reference/identite FIGEE (sans relation Prisma). input_canonical = chaine canonique
// exacte scellee ; content_hash = SHA-256 ; hmac = HMAC-SHA256 (clé PV_SIGNING_SECRET,
// jamais en base). document_html = copie FIGEE des octets du document client scelle
// (option-3, 0024) — regenerable independamment du cache MUTABLE calc_snapshots.
model OfficialPv {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  calcResultId     String   @map("calc_result_id") @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  pvNumber         String   @map("pv_number")
  userId           String   @map("user_id") @db.Uuid
  projectName      String   @map("project_name")
  engineId         String   @map("engine_id")
  engineVersion    String   @map("engine_version")
  engineSourceHash String?  @map("engine_source_hash")
  inputCanonical   String   @map("input_canonical")
  output           Json     @db.JsonB
  scienceStatus    String   @map("science_status")
  // VERDICT scelle (ADR 0012) : CONFORME / NON_CONFORME / NON_APPLICABLE. Copie
  // denormalisee de la valeur SCELLEE dans input_canonical (verite = la canonique).
  // Defaut DB 'NON_APPLICABLE' (migration 0008) ; l'app fournit toujours la valeur.
  verdict          String   @default("NON_APPLICABLE")
  contentHash      String   @map("content_hash")
  hmac             String
  sealedAt         DateTime @map("sealed_at")
  // DOCUMENT CLIENT SCELLE (option-3, 0024) : copie IMMUABLE des octets du print_html
  // au scellement. NULL = PV sans capture (retro-compat -> fallback PDF). L'integrite
  // reste re-verifiable : sha256(document_html) doit egaler document.sha256 (scelle
  // dans input_canonical). document_format = 'html' quand present.
  documentHtml     String?  @map("document_html")
  documentFormat   String?  @map("document_format")

  @@unique([orgId, pvNumber]) // numero unique par org
  @@unique([orgId, calcResultId]) // idempotence d'emission : 1 calcul -> 1 PV
  @@index([orgId])
  // P0-6 : official_pvs n'avait QUE (org_id). Les agregats de P0-1/P0-3
  // (compte des PV, date du dernier scellement) filtrent par project_id :
  // sans cet index, chaque liste parcourait tout l'org.
  @@index([orgId, projectId, sealedAt(sort: Desc)])
  @@map("official_pvs")
}

// Compteur de numerotation PAR ORG et PAR ANNEE (PV-RDS-{slug}-{YYYY}-{NNNNNN}).
// Incremente atomiquement par allocate_pv_number(year) (0006), sous RLS FORCE.
model PvCounter {
  orgId   String @map("org_id") @db.Uuid
  year    Int
  lastSeq BigInt @default(0) @map("last_seq")

  @@id([orgId, year])
  @@map("pv_counters")
}

// ----------------------- Abonnements & ledger d'usage (ADR 0009/0011) -----------------------
//
//  subscriptions : 1 abonnement actif par org (org_id UNIQUE). usage_ledger :
//  journal append-only de la consommation (la verite auditable). RLS FORCE +
//  policies + FK composite + triggers d'immuabilite (usage_ledger) + GRANTs
//  minimaux : portes par la migration SQL 0008 (Prisma seul ne les exprime pas).
//  Voir prisma/migrations/0008_subscriptions_usage_ledger/migration.sql.

// Abonnement d'une organisation. `entitlements` = engineId/features debloques
// (STOCKE explicitement, derive du pack). `quota` NON-NULL fini (le decompte
// atomique WHERE consommation < quota casserait sur NULL). `consommation` =
// compteur materialise reconciliable par COUNT(*) du ledger.
model Subscription {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @unique @map("org_id") @db.Uuid
  pack         String
  entitlements String[]
  dateDebut    DateTime @map("date_debut") @db.Timestamptz()
  dateFin      DateTime @map("date_fin") @db.Timestamptz()
  quota        Int
  consommation Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  org    Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ledger UsageLedger[]

  @@unique([orgId, id]) // cible de la FK COMPOSITE (org_id, .) du ledger
  @@index([orgId])
  @@map("subscriptions")
}

// Journal APPEND-ONLY des actions admin (back-office SUPERADMIN, Lot 2). HORS-tenant
// (cross-tenant par nature : un SUPERADMIN agit sur n'importe quelle org) -> PAS de
// policy RLS tenant ; RLS FORCE gatee sur app_auth_bootstrap() + immuabilite (triggers
// 0013). DEFINER-ONLY : ecrit par adjust_quota/renew/... et lu par admin_list_audit
// (fonctions SECURITY DEFINER) ; le runtime roadsen_app n'a AUCUN GRANT dessus. Ne PAS
// l'interroger via le client Prisma (RLS -> 0 ligne hors drapeau). idempotencyKey UNIQUE
// = anti double-credit. Aucune FK : le journal survit a la suppression d'org/user.
// Portee SQL : voir prisma/migrations/0013_backoffice_admin_mutations/migration.sql.
model AdminAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  actorUserId    String   @map("actor_user_id") @db.Uuid
  action         String
  targetOrgId    String?  @map("target_org_id") @db.Uuid
  targetUserId   String?  @map("target_user_id") @db.Uuid
  payload        Json     @default("{}") @db.JsonB
  idempotencyKey String   @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([targetOrgId, createdAt])
  @@map("admin_audit_log")
}

// Journal d'usage APPEND-ONLY (immuable via triggers 0008 ; runtime sans
// UPDATE/DELETE). FK COMPOSITE (orgId, subscriptionId) -> subscriptions(orgId, id) :
// un ledger ne rattache que l'abonnement de SON tenant.
model UsageLedger {
  id             String   @id @default(uuid()) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  kind           String
  refId          String?  @map("ref_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  subscription Subscription @relation(fields: [orgId, subscriptionId], references: [orgId, id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, subscriptionId])
  @@map("usage_ledger")
}

# ====================================================================
# ROADSEN - variables d environnement (modele).
# Copier en .env  (jamais commite) :  cp .env.example .env
# En preprod/prod : renseigner via le dashboard Render (Environment).
# ====================================================================

# --- Environnement ---
NODE_ENV=development

# --- Base de donnees (local docker-compose) ---
# Format Prisma. En managed (Render), utiliser l URL fournie + ?sslmode=require
DATABASE_URL="postgresql://roadsen:roadsen_dev@localhost:5432/roadsen_dev?schema=public"

# Connexion "shadow" pour les migrations Prisma en dev (peut etre une base locale dediee).
SHADOW_DATABASE_URL="postgresql://roadsen:roadsen_dev@localhost:5432/roadsen_shadow?schema=public"

# --- API ---
API_PORT=3001
API_BASE_URL="http://localhost:3001"
# Origines autorisees CORS (front), separees par des virgules.
CORS_ORIGINS="http://localhost:3000"

# --- Authentification (JWT) ---
# Generer une valeur forte :  openssl rand -base64 48
JWT_SECRET="changeme-dev-only-generate-with-openssl-rand"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# --- Scellement des PV (integrite des livrables) ---
# Cle de signature/hash des PV. Distincte de JWT_SECRET. A faire tourner avec prudence.
PV_SIGNING_SECRET="changeme-dev-only-generate-with-openssl-rand"

# --- Front (Next.js) ---
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_APP_ENV=development

# --- Cloudflare R2 (stockage PV/PDF - Phase 2) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="roadsen-pv-dev"
R2_ENDPOINT=""

# --- Observabilite (Sentry - preprod/prod) ---
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# --- Integrations Phase 2 (placeholders, non utilises en Phase 1) ---
RESEND_API_KEY=""
PAYDUNYA_MASTER_KEY=""
PAYDUNYA_PRIVATE_KEY=""
PAYDUNYA_PUBLIC_KEY=""
PAYDUNYA_TOKEN=""
PAYDUNYA_MODE="test"
